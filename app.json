{
  "expo": {
    "name": "AngoTrack",
    "slug": "ango-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "angotrack",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.angotrack.shipper",
      "config": {
        "googleMapsApiKey": "AIzaSyAjP53PmBT5XcqzyZ3ew2_8LwKwV2TnvT4"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AngoTrack needs your location to show nearby drivers.",
        "NSCameraUsageDescription": "AngoTrack needs camera access for proof of delivery photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.angotrack.shipper",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAjP53PmBT5XcqzyZ3ew2_8LwKwV2TnvT4"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ]
  }
}
